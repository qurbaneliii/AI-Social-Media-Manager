# Core
NODE_ENV=development
PORT=3000
API_PORT=4000

# Auth0
AUTH0_DOMAIN=example.us.auth0.com
AUTH0_AUDIENCE=https://api.aria.local
AUTH0_ISSUER_BASE_URL=https://example.us.auth0.com/
AUTH0_CLIENT_ID=replace-me
AUTH0_CLIENT_SECRET=replace-me

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_BUCKET=aria-media
AWS_KMS_KEY_ID=replace-me
AWS_SECRETS_MANAGER_PREFIX=/aria

# Databases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aria
TIMESCALE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aria_timescale
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=aria
KAFKA_GROUP_ID=aria-consumers

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aria-task-queue

# LLM
OPENAI_API_KEY=replace-me
ANTHROPIC_API_KEY=replace-me
MISTRAL_API_KEY=replace-me
DEEPSEEK_API_KEY=replace-me

# Observability
OTEL_SERVICE_NAME=aria
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9464

# mTLS
MTLS_CA_CERT_PATH=/certs/ca.crt
MTLS_CLIENT_CERT_PATH=/certs/client.crt
MTLS_CLIENT_KEY_PATH=/certs/client.key

# Webhooks
WEBHOOK_HMAC_SECRET=replace-me
ANALYTICS_INGEST_API_KEY=replace-me
INTERNAL_SERVICE_TOKEN=replace-me
