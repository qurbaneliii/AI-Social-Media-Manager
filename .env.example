LLM_PROXY_URL=http://host.docker.internal:8000
SERVICE_NAME=aria-service
SERVICE_VERSION=1.0.0
OTLP_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=INFO
AWS_REGION=us-east-1
KMS_KEY_ID=local-kms-key
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=aria
TEMPORAL_TASK_QUEUE=aria-task-queue

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aria-media

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=

DESCRIPTIVE_PRIOR_WEIGHT=0.40
CORPUS_STATS_WEIGHT=0.35
ENGAGEMENT_DELTA_WEIGHT=0.25
SPARSE_SAMPLE_CONFIDENCE_CAP=0.65
