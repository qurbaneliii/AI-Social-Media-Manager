{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aria.schemas/events/company.profile.submitted.v1.schema.json",
  "allOf": [
    { "$ref": "./_envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "company.profile.submitted.v1" },
        "payload": {
          "type": "object",
          "required": ["profile_version", "submitted_at"],
          "properties": {
            "profile_version": { "type": "integer", "minimum": 1 },
            "submitted_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
