generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

enum MembershipRole {
  owner
  admin
  editor
  viewer
}

enum PostStatus {
  draft
  generating
  generated
  approved
  scheduled
  published
  failed
}

enum ScheduleStatus {
  queued
  awaiting_approval
  approved
  publishing
  published
  failed
  dead_letter
}

enum ApprovalMode {
  human
  auto
}

enum PlatformType {
  instagram
  linkedin
  facebook
  x
  tiktok
  pinterest
}

enum PromptStatus {
  active
  disabled
  archived
}

enum MetricSource {
  webhook
  pull
  manual
}

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(120)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  users       User[]
  companies   Company[]

  @@map("tenants")
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  email         String        @unique @db.VarChar(255)
  displayName   String        @map("display_name") @db.VarChar(120)
  auth0UserId   String        @unique @map("auth0_user_id") @db.VarChar(255)
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  memberships   Membership[]

  @@index([tenantId])
  @@map("users")
}

model Company {
  id                            String                      @id @default(uuid()) @db.Uuid
  tenantId                      String                      @map("tenant_id") @db.Uuid
  name                          String                      @db.VarChar(120)
  industryVertical              String                      @map("industry_vertical") @db.VarChar(120)
  targetMarketJson              Json                        @map("target_market_json")
  platformPresenceJson          Json                        @map("platform_presence_json")
  postingFrequencyGoalJson      Json                        @map("posting_frequency_goal_json")
  createdAt                     DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                     DateTime?                   @map("deleted_at") @db.Timestamptz(6)

  tenant                        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  memberships                   Membership[]
  brandProfiles                 BrandProfile[]
  competitors                   Competitor[]
  mediaAssets                   MediaAsset[]
  posts                         Post[]
  schedules                     Schedule[]
  platformCredentials           PlatformCredential[]
  performanceMetrics            PerformanceMetric[]
  auditLogs                     AuditLog[]
  brandVoiceEmbeddings          BrandVoiceEmbedding[]
  hashtagEmbeddings             HashtagEmbedding[]
  postArchiveEmbeddings         PostArchiveEmbedding[]
  audienceProfileEmbeddings     AudienceProfileEmbedding[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@map("companies")
}

model Membership {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  companyId   String          @map("company_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  role        MembershipRole
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([tenantId])
  @@index([companyId])
  @@index([userId])
  @@map("memberships")
}

model BrandProfile {
  id                          String                      @id @default(uuid()) @db.Uuid
  tenantId                    String                      @map("tenant_id") @db.Uuid
  companyId                   String                      @map("company_id") @db.Uuid
  profileVersion              Int                         @default(1) @map("profile_version")
  brandPositioningStatement   String                      @map("brand_positioning_statement") @db.VarChar(500)
  toneOfVoiceDescriptors      String[]                    @map("tone_of_voice_descriptors")
  competitorList              String[]                    @default([]) @map("competitor_list")
  primaryCtaTypes             String[]                    @default([]) @map("primary_cta_types")
  brandColorHexCodes          String[]                    @default([]) @map("brand_color_hex_codes")
  approvedVocabularyList      String[]                    @default([]) @map("approved_vocabulary_list")
  bannedVocabularyList        String[]                    @default([]) @map("banned_vocabulary_list")
  toneFingerprintJson         Json?                       @map("tone_fingerprint_json")
  visualStyleJson             Json?                       @map("visual_style_json")
  createdAt                   DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                     Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, profileVersion])
  @@index([tenantId])
  @@index([companyId])
  @@map("brand_profiles")
}

model Competitor {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  name        String      @db.VarChar(120)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@map("competitors")
}

model MediaAsset {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  companyId   String           @map("company_id") @db.Uuid
  s3Key       String           @map("s3_key") @db.VarChar(512)
  mimeType    String           @map("mime_type") @db.VarChar(120)
  sizeBytes   BigInt           @map("size_bytes")
  status      String           @db.VarChar(50)
  uploadedAt  DateTime         @map("uploaded_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  analyses    MediaAnalysis[]

  @@index([tenantId])
  @@index([companyId])
  @@index([s3Key])
  @@map("media_assets")
}

model MediaAnalysis {
  id                 String      @id @default(uuid()) @db.Uuid
  tenantId           String      @map("tenant_id") @db.Uuid
  companyId          String      @map("company_id") @db.Uuid
  mediaId            String      @map("media_id") @db.Uuid
  ocrText            String?     @map("ocr_text") @db.Text
  paletteJson        Json        @map("palette_json")
  typographyJson     Json        @map("typography_json")
  layoutJson         Json        @map("layout_json")
  styleJson          Json        @map("style_json")
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  media              MediaAsset  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@index([mediaId])
  @@map("media_analysis")
}

model Post {
  id                      String            @id @default(uuid()) @db.Uuid
  tenantId                String            @map("tenant_id") @db.Uuid
  companyId               String            @map("company_id") @db.Uuid
  postIntent              String            @map("post_intent") @db.VarChar(50)
  coreMessage             String            @map("core_message") @db.VarChar(500)
  targetPlatforms         PlatformType[]    @map("target_platforms")
  campaignTag             String?           @map("campaign_tag") @db.VarChar(120)
  attachedMediaId         String?           @map("attached_media_id") @db.Uuid
  manualKeywords          String[]          @default([]) @map("manual_keywords")
  urgencyLevel            String            @map("urgency_level") @db.VarChar(20)
  requestedPublishAt      DateTime?         @map("requested_publish_at") @db.Timestamptz(6)
  status                  PostStatus        @default(generating)
  contextSnapshotJson     Json?             @map("context_snapshot_json")
  generatedPackageJson    Json?             @map("generated_package_json")
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                 Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  variants                PostVariant[]
  schedules               Schedule[]
  performanceMetrics      PerformanceMetric[]

  @@index([tenantId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("posts")
}

model PostVariant {
  id                      String          @id @default(uuid()) @db.Uuid
  tenantId                String          @map("tenant_id") @db.Uuid
  companyId               String          @map("company_id") @db.Uuid
  postId                  String          @map("post_id") @db.Uuid
  platform                PlatformType
  variantRank             Int             @map("variant_rank")
  captionText             String          @map("caption_text") @db.Text
  hashtags                String[]        @default([])
  score                   Decimal         @db.Decimal(6, 3)
  scoringMetadataJson     Json            @map("scoring_metadata_json")
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  post                    Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@index([postId])
  @@index([platform, variantRank])
  @@map("post_variants")
}

model Schedule {
  id                      String          @id @default(uuid()) @db.Uuid
  tenantId                String          @map("tenant_id") @db.Uuid
  companyId               String          @map("company_id") @db.Uuid
  postId                  String          @map("post_id") @db.Uuid
  platform                PlatformType
  runAtUtc                DateTime        @map("run_at_utc") @db.Timestamptz(6)
  approvalMode            ApprovalMode    @map("approval_mode")
  status                  ScheduleStatus  @default(queued)
  retryCount              Int             @default(0) @map("retry_count")
  externalPostId          String?         @map("external_post_id") @db.VarChar(255)
  idempotencyKey          String          @map("idempotency_key") @db.VarChar(120)
  timezone                String?         @db.VarChar(50)
  forceWindow             Boolean         @default(false) @map("force_window")
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                 Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  post                    Post            @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([companyId, platform, runAtUtc])
  @@unique([idempotencyKey])
  @@index([tenantId])
  @@index([companyId])
  @@index([postId])
  @@index([runAtUtc, status])
  @@map("schedules")
}

model PlatformCredential {
  id                      String          @id @default(uuid()) @db.Uuid
  tenantId                String          @map("tenant_id") @db.Uuid
  companyId               String          @map("company_id") @db.Uuid
  platform                PlatformType
  encryptedTokenCiphertext Bytes          @map("encrypted_token_ciphertext") @db.Bytea
  encryptedTokenIv        Bytes           @map("encrypted_token_iv") @db.Bytea
  encryptedTokenTag       Bytes           @map("encrypted_token_tag") @db.Bytea
  kmsEncryptedDataKey     Bytes           @map("kms_encrypted_data_key") @db.Bytea
  tokenExpiresAt          DateTime?       @map("token_expires_at") @db.Timestamptz(6)
  metadataJson            Json            @map("metadata_json")
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                 Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, platform])
  @@index([tenantId])
  @@index([companyId])
  @@map("platform_credentials")
}

model PromptTemplate {
  id                      String        @id @default(uuid()) @db.Uuid
  tenantId                String        @map("tenant_id") @db.Uuid
  companyId               String?       @map("company_id") @db.Uuid
  name                    String        @db.VarChar(120)
  version                 Int
  status                  PromptStatus  @default(active)
  templateBody            String        @map("template_body") @db.Text
  variablesJson           Json          @map("variables_json")
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([tenantId, name, version])
  @@index([companyId])
  @@index([tenantId])
  @@map("prompt_templates")
}

model PerformanceMetric {
  id                      String       @id @default(uuid()) @db.Uuid
  tenantId                String       @map("tenant_id") @db.Uuid
  companyId               String       @map("company_id") @db.Uuid
  postId                  String       @map("post_id") @db.Uuid
  platform                PlatformType
  externalPostId          String       @map("external_post_id") @db.VarChar(255)
  impressions             Int
  reach                   Int
  engagementRate          Decimal      @map("engagement_rate") @db.Decimal(8, 5)
  clickThroughRate        Decimal      @map("click_through_rate") @db.Decimal(8, 5)
  saves                   Int
  shares                  Int
  followerGrowthDelta     Int          @map("follower_growth_delta")
  postingTimestamp        DateTime     @map("posting_timestamp") @db.Timestamptz(6)
  capturedAt              DateTime     @map("captured_at") @db.Timestamptz(6)
  source                  MetricSource
  attributesJson          Json         @default("{}") @map("attributes_json")

  company                 Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  post                    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId, postId, platform])
  @@index([capturedAt])
  @@map("performance_metrics")
}

model AuditLog {
  id                      String      @id @default(uuid()) @db.Uuid
  tenantId                String      @map("tenant_id") @db.Uuid
  companyId               String?     @map("company_id") @db.Uuid
  actorUserId             String?     @map("actor_user_id") @db.Uuid
  action                  String      @db.VarChar(120)
  resourceType            String      @map("resource_type") @db.VarChar(80)
  resourceId              String      @map("resource_id") @db.VarChar(255)
  ipAddress               String?     @map("ip_address") @db.VarChar(64)
  userAgent               String?     @map("user_agent") @db.VarChar(512)
  metadataJson            Json        @map("metadata_json")
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company                 Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([companyId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model BrandVoiceEmbedding {
  id                      String      @id @default(uuid()) @db.Uuid
  tenantId                String      @map("tenant_id") @db.Uuid
  companyId               String      @map("company_id") @db.Uuid
  sourceType              String      @map("source_type") @db.VarChar(50)
  sourceRef               String      @map("source_ref") @db.VarChar(120)
  embedding               Unsupported("vector(1536)")
  metadataJson            Json        @map("metadata_json")
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company                 Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@map("brand_voice_embeddings")
}

model HashtagEmbedding {
  id                      String      @id @default(uuid()) @db.Uuid
  tenantId                String      @map("tenant_id") @db.Uuid
  companyId               String      @map("company_id") @db.Uuid
  hashtag                 String      @db.VarChar(80)
  embedding               Unsupported("vector(1536)")
  performanceWeight       Decimal     @default(0.0) @map("performance_weight") @db.Decimal(8, 5)
  metadataJson            Json        @map("metadata_json")
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                 Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@index([hashtag])
  @@map("hashtag_embeddings")
}

model PostArchiveEmbedding {
  id                      String      @id @default(uuid()) @db.Uuid
  tenantId                String      @map("tenant_id") @db.Uuid
  companyId               String      @map("company_id") @db.Uuid
  postId                  String      @map("post_id") @db.Uuid
  platform                PlatformType
  embedding               Unsupported("vector(1536)")
  metadataJson            Json        @map("metadata_json")
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company                 Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@index([postId])
  @@map("post_archive_embeddings")
}

model AudienceProfileEmbedding {
  id                      String      @id @default(uuid()) @db.Uuid
  tenantId                String      @map("tenant_id") @db.Uuid
  companyId               String      @map("company_id") @db.Uuid
  audienceSegment         String      @map("audience_segment") @db.VarChar(120)
  embedding               Unsupported("vector(1536)")
  metadataJson            Json        @map("metadata_json")
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  company                 Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@index([audienceSegment])
  @@map("audience_profile_embeddings")
}

model IdempotencyKey {
  key                     String      @id @db.VarChar(120)
  tenantId                String      @map("tenant_id") @db.Uuid
  companyId               String      @map("company_id") @db.Uuid
  scope                   String      @db.VarChar(80)
  responseJson            Json        @map("response_json")
  expiresAt               DateTime    @map("expires_at") @db.Timestamptz(6)
  createdAt               DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
