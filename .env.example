# Canonical environment template for local, Docker, and Codespaces runtime.

# Core database/bootstrap
POSTGRES_USER=aria
POSTGRES_PASSWORD=aria
POSTGRES_DB=aria
DATABASE_URL=postgresql://aria:aria@postgres:5432/aria
POSTGRES_DSN=postgresql://aria:aria@postgres:5432/aria
FRONTEND_DATABASE_URL=postgresql://aria:aria@postgres:5432/aria

# Cache/queue/infra
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aria-main
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=aria-media

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PREVIEW_MODE=true
NEXT_PUBLIC_AI_REQUEST_TIMEOUT_MS=45000
NEXT_PUBLIC_AI_REQUEST_RETRIES=2
# SECURITY: replace before running any shared or production-like environment.
JWT_SECRET=REPLACE_ME_OR_STARTUP_WILL_FAIL

# Backend service behavior
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000
BRAND_EMBEDDING_JSON=[]
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
FORCE_FAIL_PUBLISH=false

# Provider transport controls
LLM_PROVIDER_TIMEOUT_SECONDS=45
LLM_PROVIDER_MAX_RETRIES=2
OPENAI_REQUEST_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2
OPENAI_EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_EMBEDDING_MAX_RETRIES=2

# Provider credentials/models (set at least one provider key)
# SECURITY: keep placeholder values out of real deployments.
DEEPSEEK_API_KEY=REPLACE_ME_OR_STARTUP_WILL_FAIL
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=REPLACE_ME_OR_STARTUP_WILL_FAIL
OPENAI_MODEL=gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=REPLACE_ME_OR_STARTUP_WILL_FAIL
ANTHROPIC_MODEL=claude-3-5-haiku-latest
MISTRAL_API_KEY=REPLACE_ME_OR_STARTUP_WILL_FAIL
MISTRAL_MODEL=mistral-small-latest

# OAuth/security
# SECURITY: all values below must be replaced outside local development.
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
OAUTH_STATE_SECRET=REPLACE_ME_OR_STARTUP_WILL_FAIL
CREDENTIAL_ENCRYPTION_KEY=REPLACE_ME_OR_STARTUP_WILL_FAIL
LINKEDIN_CLIENT_ID=REPLACE_ME
LINKEDIN_CLIENT_SECRET=REPLACE_ME
LINKEDIN_AUTH_URL=https://www.linkedin.com/oauth/v2/authorization
LINKEDIN_TOKEN_URL=https://www.linkedin.com/oauth/v2/accessToken
LINKEDIN_SCOPES=r_liteprofile,r_emailaddress,w_member_social
INSTAGRAM_CLIENT_ID=REPLACE_ME
INSTAGRAM_CLIENT_SECRET=REPLACE_ME
INSTAGRAM_AUTH_URL=https://api.instagram.com/oauth/authorize
INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_SCOPES=user_profile,user_media
