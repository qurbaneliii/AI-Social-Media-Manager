# Frontend app runtime configuration
# Backend API base URL used by aria-frontend/lib/api.ts
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth signing secret for app/api/auth/* routes
JWT_SECRET=replace-with-a-long-random-secret

# OpenAI key used by app/api/ai/* route handlers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2

# Anthropic key used by app/api/generate streaming route
ANTHROPIC_API_KEY=

# Optional preview banner toggle for dashboard shell
NEXT_PUBLIC_PREVIEW_MODE=true

# Browser-side timeout/retry controls for AI endpoint calls
NEXT_PUBLIC_AI_REQUEST_TIMEOUT_MS=45000
NEXT_PUBLIC_AI_REQUEST_RETRIES=2

# Prisma datasource for auth routes and seed script
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aria
