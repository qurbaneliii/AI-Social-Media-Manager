# FILE: .env.example
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/aria
REDIS_URL=redis://redis:6379/0
S3_BUCKET=aria-media
LLM_PROXY_URL=http://api:4000
SERVICE_NAME=aria-service
SERVICE_VERSION=1.0.0
OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
LOG_LEVEL=INFO
AWS_REGION=us-east-1
KMS_KEY_ID=local-kms-key

TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aria-task-queue

DESCRIPTIVE_PRIOR_WEIGHT=0.40
CORPUS_STATS_WEIGHT=0.35
ENGAGEMENT_DELTA_WEIGHT=0.25
SPARSE_SAMPLE_CONFIDENCE_CAP=0.65
LANGUAGE_CONFIDENCE_THRESHOLD=0.8

COLOR_WEIGHT=0.40
TYPOGRAPHY_WEIGHT=0.20
LAYOUT_WEIGHT=0.20
LOGO_WEIGHT=0.20

RELEVANCE_COSINE_WEIGHT=0.35
ENGAGEMENT_UPLIFT_WEIGHT=0.35
RECENCY_TREND_WEIGHT=0.20
BRAND_FIT_WEIGHT=0.10
BROAD_THRESHOLD=500000
NICHE_LOWER=50000
NICHE_UPPER=499999
MICRO_UPPER=49999
BROAD_QUOTA=3
NICHE_QUOTA=5
MICRO_QUOTA=5
BORROW_PENALTY=0.85
PRIMARY_KW_DENSITY_MIN=0.015
PRIMARY_KW_DENSITY_MAX=0.025

COLD_START_BASELINE_WEIGHT=0.70
COLD_START_BENCHMARK_WEIGHT=0.30
COLD_START_MAX_CONFIDENCE=0.72

ENGAGEMENT_PREDICTED_WEIGHT=0.30
TONE_MATCH_WEIGHT=0.25
CTA_PRESENCE_WEIGHT=0.15
KEYWORD_INCLUSION_WEIGHT=0.15
PLATFORM_COMPLIANCE_WEIGHT=0.15

# Optional local test toggle
FORCE_FAIL_PUBLISH=false
