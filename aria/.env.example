# filename: .env.example
# purpose: Environment template for ARIA API, worker, providers, cache, and local Docker stack.
# dependencies: docker-compose.yml, app/*.py

# Core Postgres credentials used by Docker Compose and Temporal auto-setup.
POSTGRES_USER=aria
POSTGRES_PASSWORD=aria
POSTGRES_DB=aria

# Async PostgreSQL DSN used by SemanticCache (asyncpg).
POSTGRES_DSN=postgresql://aria:aria@postgres:5432/aria

# Primary asyncpg connection string for repositories, migrations, and memory jobs.
DATABASE_URL=postgresql://aria:aria@postgres:5432/aria

# Redis endpoint used for Celery broker/backend and exact-match idempotency cache.
REDIS_URL=redis://redis:6379/0

# Celery broker URL for dispatching generation jobs.
CELERY_BROKER_URL=redis://redis:6379/0

# Celery result backend URL for task state/result retrieval.
CELERY_RESULT_BACKEND=redis://redis:6379/1

# DeepSeek API key for primary LLM generation provider.
DEEPSEEK_API_KEY=replace-me
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API key for fallback generation and semantic cache embeddings.
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_EMBEDDING_MAX_RETRIES=2

# Anthropic API key for second-level generation fallback.
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Mistral API key for third-level generation fallback.
MISTRAL_API_KEY=replace-me
MISTRAL_MODEL=mistral-small-latest

# Shared provider transport controls.
LLM_PROVIDER_TIMEOUT_SECONDS=45
LLM_PROVIDER_MAX_RETRIES=2

# Default tenant/company ID used by Celery Beat scheduled re-embedding jobs.
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000

# Brand embedding JSON array used by vision brand-consistency scoring.
BRAND_EMBEDDING_JSON=[]

# Optional log level override for API and worker runtime.
LOG_LEVEL=INFO

# Optional OTEL endpoint for exporting traces to an OTLP-compatible collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Temporal connection and queue settings for posting/onboarding workflows.
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aria-main

# Browser CORS allowlist for local frontend to backend calls.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# MinIO/S3 settings for media asset upload presigning.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=aria-media

# OAuth callback and state protection.
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
OAUTH_STATE_SECRET=replace-me

# Credential encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=replace-me

# Platform OAuth templates (configure per provider as needed).
LINKEDIN_CLIENT_ID=replace-me
LINKEDIN_CLIENT_SECRET=replace-me
LINKEDIN_AUTH_URL=https://www.linkedin.com/oauth/v2/authorization
LINKEDIN_TOKEN_URL=https://www.linkedin.com/oauth/v2/accessToken
LINKEDIN_SCOPES=r_liteprofile,r_emailaddress,w_member_social

INSTAGRAM_CLIENT_ID=replace-me
INSTAGRAM_CLIENT_SECRET=replace-me
INSTAGRAM_AUTH_URL=https://api.instagram.com/oauth/authorize
INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_SCOPES=user_profile,user_media
