{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aria.schemas/events/post.publish.failed.v1.schema.json",
  "allOf": [
    { "$ref": "./_envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "event_type": { "const": "post.publish.failed.v1" },
        "payload": {
          "type": "object",
          "required": ["schedule_id", "post_id", "platform", "retry_count", "error", "failed_at"],
          "properties": {
            "schedule_id": { "type": "string", "format": "uuid" },
            "post_id": { "type": "string", "format": "uuid" },
            "platform": { "enum": ["instagram", "linkedin", "facebook", "x", "tiktok", "pinterest"] },
            "retry_count": { "type": "integer", "minimum": 1 },
            "error": {
              "type": "object",
              "required": ["code", "message"],
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" }
              },
              "additionalProperties": false
            },
            "failed_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
